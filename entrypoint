#!/bin/bash
set -e

# Self-modification support:
# If SANDBOX_SELF_MODIFY=1, the sandbox source is mounted at
# $HOME/.sandbox-source. Symlink any skills from there
# into ~/.pi/agent/skills/ for auto-discovery.
SANDBOX_SRC="$HOME/.sandbox-source"
if [[ "${SANDBOX_SELF_MODIFY:-0}" == "1" && -d "$SANDBOX_SRC/skills" ]]; then
    SKILL_DIR="$HOME/.pi/agent/skills"
    mkdir -p "$SKILL_DIR"
    for skill in "$SANDBOX_SRC/skills"/*/; do
        name=$(basename "$skill")
        ln -sfn "$SANDBOX_SRC/skills/$name" "$SKILL_DIR/$name"
    done
fi

# Extension enablement:
# pi-sandbox sets PI_ENABLED_EXTENSIONS (comma-separated) based on user flags.
# We run pi with -ne (disable auto-discovery) and -e <path> for each enabled
# extension. This gives explicit control over which sandbox extensions are loaded.
#
# Available extensions are symlinked in $HOME/.agent-sandbox/pi-extensions/<name>.
# The entrypoint resolves each enabled name to its path and builds -e flags.
#
# If the container command is NOT pi (e.g., "bash"), we skip extension injection
# and exec the command as-is.

PI_EXT_DIR="$HOME/.agent-sandbox/pi-extensions"

# Decide whether to inject extension flags into pi, or exec as-is.
# - No args (default CMD "pi")        → inject
# - First arg is "pi"                 → inject, shift past "pi"
# - First arg starts with "-"         → inject (treat as pi flags)
# - Anything else (e.g., "bash")     → exec as-is
if [ $# -eq 0 ] || [ "$1" = "pi" ] || [ "${1#-}" != "$1" ]; then
    # Build the pi command line: pi -ne -e <ext1> [-e <ext2>] ... [user-args]
    PI_ARGS=(-ne)

    IFS=',' read -ra EXT_NAMES <<< "${PI_ENABLED_EXTENSIONS:-}"
    for name in "${EXT_NAMES[@]}"; do
        ext_path="$PI_EXT_DIR/$name"
        if [ -d "$ext_path" ]; then
            PI_ARGS+=(-e "$ext_path")
        else
            echo "Warning: enabled extension '$name' not found at $ext_path" >&2
        fi
    done

    # Collect original args (skip leading "pi" if present)
    if [ $# -gt 0 ] && [ "$1" = "pi" ]; then
        shift
    fi

    exec pi "${PI_ARGS[@]}" "$@"
else
    # Not a pi command (e.g., bash, sh, node) — exec directly
    exec "$@"
fi