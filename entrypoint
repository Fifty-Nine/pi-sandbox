#!/bin/bash
set -e

# Self-modification support:
# If SANDBOX_SELF_MODIFY=1, the sandbox source is mounted at
# $HOME/.sandbox-source. Symlink any skills from there
# into ~/.pi/agent/skills/ for auto-discovery.
SANDBOX_SRC="$HOME/.sandbox-source"
if [[ "${SANDBOX_SELF_MODIFY:-0}" == "1" && -d "$SANDBOX_SRC/skills" ]]; then
    SKILL_DIR="$HOME/.pi/agent/skills"
    mkdir -p "$SKILL_DIR"
    for skill in "$SANDBOX_SRC/skills"/*/; do
        name=$(basename "$skill")
        ln -sfn "$SANDBOX_SRC/skills/$name" "$SKILL_DIR/$name"
    done
fi

# Create extension symlinks in ~/.pi/agent/extensions/ for pi auto-discovery.
# Each subdirectory in $HOME/.pi-sandbox/pi-extensions/ is symlinked.
EXT_DIR="$HOME/.pi/agent/extensions"
SRC_DIR="$HOME/.pi-sandbox/pi-extensions"

if [ -d "$SRC_DIR" ]; then
    mkdir -p "$EXT_DIR"
    for entry in "$SRC_DIR"/*; do
        name=$(basename "$entry")
        # Resolve to actual target (in case entry itself is a symlink)
        resolved=$(readlink -f "$entry")
        target="$EXT_DIR/$name"
        ln -sfn "$resolved" "$target"
    done
fi

exec "$@"
