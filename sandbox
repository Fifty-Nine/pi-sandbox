#!/usr/bin/env bash
set -euo pipefail

IMAGE=agent-sandbox

# Detect the sandbox username from the Docker image label (set during build).
# Falls back to "agent" if the image doesn't exist or the label is missing.
SANDBOX_USER=$(docker image inspect --format '{{index .Config.Labels "sandbox.user"}}' "$IMAGE" 2>/dev/null) || true
if [[ -z "$SANDBOX_USER" || "$SANDBOX_USER" == *"<no value>"* ]]; then
    SANDBOX_USER=agent
fi

RW=false
SELF_MODIFY=false
NO_MOUNT=false
TMUX_MODE=false
TMUX_SOCKET=""
SSH_MODE=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -w|--read-write) RW=true; shift ;;
        -s|--self-modify) SELF_MODIFY=true; shift ;;
        -S|--ssh) SSH_MODE=true; shift ;;
        -x|--no-mount) NO_MOUNT=true; shift ;;
        --tmux)
            TMUX_MODE=true
            if [[ $# -gt 1 && ! "$2" =~ ^- ]]; then
                TMUX_SOCKET="$(readlink -f $2)"
                shift 2
            else
                # Auto-detect: extract socket path from $TMUX or use default
                if [[ -n "${TMUX:-}" ]]; then
                    TMUX_SOCKET="${TMUX%%,*}"
                else
                    TMUX_SOCKET="/tmp/tmux-$(id -u)/default"
                fi
                shift
            fi
            ;;
        --) shift; break ;;
        -h|--help)
            echo "Usage: $(basename "$0") [-w|--read-write] [-s|--self-modify] [--tmux [SOCKET]] [--] [COMMAND...]"
            echo ""
            echo "Launch the agent-sandbox Docker container."
            echo ""
            echo "Options:"
            echo "  -w, --read-write    Mount the working directory read-write (default: read-only)"
            echo "  -x, --no-mount     Do not mount the working directory at all; the agent works"
            echo "                      from /home/<username> (read-write) instead"
            echo "  -S, --ssh           Forward the host SSH agent and mount ~/.ssh read-only so the"
            echo "                      agent can connect to remote hosts via SSH"
            echo "  -s, --self-modify   Mount the sandbox source directory read-write so the agent"
            echo "                      can modify the sandbox itself (Dockerfile, entrypoint, etc.)"
            echo "  --tmux [SOCKET]     Mount a tmux socket for the tmux debugging tool."
            echo "                      SOCKET defaults to the current tmux session's socket."
            echo "  --                  End of options; remaining args override the container CMD"
            exit 0
            ;;
        -*) echo "Unknown option: $1" >&2; exit 1 ;;
        *)  break ;;            # first non-flag is the start of the command
    esac
done

# Transform host paths to container paths:
#   $HOME/.pi          -> /home/<SANDBOX_USER>/.pi
#   $PWD (under $HOME) -> /home/<SANDBOX_USER>/<relative-path>
CONTAINER_HOME=/home/$SANDBOX_USER

DOCKER_ARGS=(
    --mount "type=bind,source=$HOME/.pi,target=$CONTAINER_HOME/.pi"
)

if $NO_MOUNT; then
    # No CWD mount — agent works from /home/$SANDBOX_USER (read-write by default)
    AGENT_PWD=$CONTAINER_HOME
else
    AGENT_PWD="${PWD/#$HOME/$CONTAINER_HOME}"
    if $RW; then
        PWD_MOUNT="type=bind,source=$PWD,target=$AGENT_PWD"
    else
        PWD_MOUNT="type=bind,source=$PWD,target=$AGENT_PWD,readonly"
    fi
    DOCKER_ARGS+=(
        --mount "$PWD_MOUNT"
    )
fi

DOCKER_ARGS+=(
    -w "$AGENT_PWD"
)

# Self-modify: mount the sandbox source directory read-write
if $SELF_MODIFY; then
    SANDBOX_SOURCE_DIR="$(cd "$(dirname "$0")" && pwd)"
    DOCKER_ARGS+=(
        --mount "type=bind,source=$SANDBOX_SOURCE_DIR,target=$CONTAINER_HOME/.sandbox-source"
        --env SANDBOX_SELF_MODIFY=1
        --env SANDBOX_SOURCE_DIR=$CONTAINER_HOME/.sandbox-source
    )
fi

# Tmux debug mode: mount the tmux socket directory and set env vars
if $TMUX_MODE; then
    if [[ ! -S "$TMUX_SOCKET" ]]; then
        echo "Error: tmux socket not found at $TMUX_SOCKET" >&2
        echo "Make sure you are inside a tmux session, or provide the socket path: --tmux /path/to/socket" >&2
        exit 1
    fi
    TMUX_SOCKET_DIR=$(dirname "$TMUX_SOCKET")
    TMUX_MOUNTED_SOCKET_PATH=/tmux-socket-dir/$(basename "$TMUX_SOCKET")
    DOCKER_ARGS+=(
        --mount "type=bind,source=$TMUX_SOCKET_DIR,target=/tmux-socket-dir"
        --env TMUX_SOCKET_PATH=$TMUX_MOUNTED_SOCKET_PATH
        --env TMUX_DEBUG_MODE=1
    )
fi

# SSH mode: forward SSH agent socket and mount ~/.ssh read-only
if $SSH_MODE; then
    if [[ -z "${SSH_AUTH_SOCK:-}" ]]; then
        echo "Error: SSH_AUTH_SOCK is not set. Is ssh-agent running?" >&2
        exit 1
    fi
    if [[ ! -S "$SSH_AUTH_SOCK" ]]; then
        echo "Error: SSH_AUTH_SOCK ($SSH_AUTH_SOCK) does not exist or is not a socket" >&2
        exit 1
    fi
    SSH_AUTH_SOCK_REAL="$(readlink -f "$SSH_AUTH_SOCK")"
    SSH_AUTH_SOCK_DIR="$(dirname "$SSH_AUTH_SOCK_REAL")"
    SSH_AUTH_SOCK_BASE="$(basename "$SSH_AUTH_SOCK_REAL")"
    SSH_MOUNTED_SOCK="/ssh-agent-socket/$SSH_AUTH_SOCK_BASE"
    DOCKER_ARGS+=(
        --mount "type=bind,source=$SSH_AUTH_SOCK_DIR,target=/ssh-agent-socket"
        --env SSH_AUTH_SOCK=$SSH_MOUNTED_SOCK
        --mount "type=bind,source=$HOME/.ssh,target=$CONTAINER_HOME/.ssh,readonly"
    )
fi

exec docker run -it --rm "${DOCKER_ARGS[@]}" "$IMAGE" "$@"
